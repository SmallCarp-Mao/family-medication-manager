# ========================================
# Docker 环境变量配置文件
# ========================================
# 使用说明：
# 1. 复制此文件为 .env.docker
# 2. 修改以下配置项的值
# 3. 运行 docker-compose 时会自动加载此配置

# ========================================
# MySQL 数据库配置
# ========================================
# MySQL root 用户密码（生产环境请修改）
MYSQL_ROOT_PASSWORD=root_password_123456

# 应用数据库用户名
MYSQL_USER=family_med_user

# 应用数据库密码（生产环境请修改）
MYSQL_PASSWORD=med_password_123456

# ========================================
# JWT 认证配置
# ========================================
# JWT 密钥（生产环境请使用随机字符串，至少32位）
JWT_SECRET=your_jwt_secret_key_please_change_in_production

# ========================================
# 微信公众号配置（可选）
# ========================================
# 微信公众号 AppID
WECHAT_APP_ID=

# 微信公众号 AppSecret
WECHAT_APP_SECRET=

# ========================================
# OSS 对象存储配置（可选）
# ========================================
# 阿里云 OSS AccessKey ID
ALI_OSS_ACCESS_KEY_ID=

# 阿里云 OSS AccessKey Secret
ALI_OSS_ACCESS_KEY_SECRET=

# 阿里云 OSS Bucket
ALI_OSS_BUCKET=

# 阿里云 OSS Region
ALI_OSS_REGION=

# ========================================
# 其他配置
# ========================================
# 后端服务端口
BACKEND_PORT=3000

# 前端服务端口
FRONTEND_PORT=80

# 后台管理端口
ADMIN_PORT=8080
